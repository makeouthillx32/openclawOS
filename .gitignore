# ============================================================
# openclawOS — root .gitignore
# Covers: .openclaw config + mission-control (Next.js)
# ============================================================

# ── SECRETS (NEVER commit these) ────────────────────────────
.env
.env.local
.env.*.local
*.pem

# ── OPENCLAW SENSITIVE FILES ─────────────────────────────────
# Device identity and private keys
identity/device.json
identity/device-auth.json

# Paired device tokens
devices/paired.json

# Main config (contains API keys and gateway token)
openclaw.json
openclaw.json.bak
openclaw.json.bak.*

# Agent auth
agents/*/agent/auth.json

# Gateway command file
gateway.cmd

# Update check
update-check.json

# ── OPENCLAW RUNTIME/NOISY FILES ─────────────────────────────
# Sessions (huge, noisy, not useful in git)
agents/*/sessions/*.jsonl
agents/*/sessions/sessions.json

# Cron run history
cron/runs/*.jsonl
cron/jobs.json.bak

# Memory database
memory/*.sqlite
memory/*.db

# Logs
logs/*.jsonl

# Canvas (auto-generated)
canvas/

# Completions (auto-generated by openclaw)
completions/

# ── MISSION-CONTROL (Next.js) ────────────────────────────────
mission-control/.next/
mission-control/out/
mission-control/build/
mission-control/node_modules/
mission-control/.pnp
mission-control/.pnp.*

# mission-control env (root .env covers these too, but explicit is safer)
mission-control/.env
mission-control/.env.local
mission-control/.env.*.local

# mission-control operational data (not example files)
mission-control/data/*.json
!mission-control/data/*.example.json
mission-control/data/*.db
mission-control/data/*.sqlite
mission-control/data/*.sqlite3

# mission-control build artifacts
mission-control/*.tsbuildinfo
mission-control/next-env.d.ts

# misc
.DS_Store
Thumbs.db